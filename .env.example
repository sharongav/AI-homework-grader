# ─────────────────────────────────────────────────────────────
# Environment Variables — AI Homework Grader Platform
# Copy to .env.local and fill in real values. Never commit .env.local.
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/homework_platform?schema=public"

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Object Storage (S3-compatible) ────────────────────────────
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET_US="homework-us"
S3_BUCKET_EU="homework-eu"
S3_REGION="us-east-1"

# ── Auth (Clerk) ──────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"

# ── OpenAI (Grading Path — Frontier Model) ───────────────────
OPENAI_API_KEY=""
OPENAI_API_KEY_EU=""
# Model identifiers are stored in PlatformConfig DB table
# OPENAI_GRADING_MODEL is resolved from PlatformConfig.gradingModelSnapshot

# ── Voyage AI (Embeddings) ────────────────────────────────────
VOYAGE_API_KEY=""

# ── Cohere (Reranker) ────────────────────────────────────────
COHERE_API_KEY=""

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@homework.example.com"

# ── Monitoring ────────────────────────────────────────────────
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
OTEL_SERVICE_NAME="homework-platform"
BETTERSTACK_SOURCE_TOKEN=""

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ── Sandbox ───────────────────────────────────────────────────
SANDBOX_DOCKER_IMAGE="homework-sandbox:latest"
SANDBOX_TIMEOUT_MS="30000"
SANDBOX_MAX_MEMORY_MB="256"

# ── Super Admin Bootstrap ─────────────────────────────────────
# One-time token for first Super Admin account claim
# Generate with: openssl rand -hex 32
SUPER_ADMIN_BOOTSTRAP_TOKEN=""
